# Django
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL
DB_NAME=litigation_db
DB_USER=litigation_user
DB_PASSWORD=litigation_pass
DB_HOST=localhost
DB_PORT=5432

# CourtListener
COURTLISTENER_API_TOKEN=your_api_token_here
COURTLISTENER_BASE_URL=https://www.courtlistener.com/api/rest/v3
TARGET_COURT=dcd

# Pipeline
POLL_INTERVAL_SECONDS=300
PDF_TEXT_MIN_LENGTH=500
SUMMARY_MAX_CHARS=2000
